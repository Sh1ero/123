<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OUR CARS | ANIMATED STYLES</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        h1 {
            text-align: center;
            font-size: 48px;
            margin-bottom: 10px;
            background: linear-gradient(90deg, #fff, #ff6600);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sub {
            text-align: center;
            opacity: 0.7;
            margin-bottom: 40px;
            color: white;
        }

        .tabs {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            margin-bottom: 35px;
        }

        .tab-btn {
            padding: 12px 28px;
            font-size: 16px;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
            background: #222;
            color: white;
        }

        .tab-btn:hover {
            transform: translateY(-3px);
        }

        .tab-btn.active {
            background: #ff6600;
            box-shadow: 0 0 15px #ff6600;
        }

        .tab-content {
            display: none;
            border-radius: 30px;
            padding: 35px;
            animation: fade 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fade {
            from { opacity: 0; transform: translateY(15px);}
            to { opacity: 1; transform: translateY(0);}
        }

        .car-img {
            width: 100%;
            max-width: 550px;
            height: auto;
            border-radius: 20px;
            display: block;
            margin: 20px auto;
            box-shadow: 0 0 30px rgba(0,0,0,0.5);
            position: relative;
            z-index: 2;
        }

        .face-img {
            width: 160px;
            height: 160px;
            object-fit: cover;         
            display: block;
            margin: 10px auto;
            border: 3px solid;
            position: relative;
            z-index: 2;
        }

        h2 {
            text-align: center;
            font-size: 32px;
            margin-bottom: 5px;
            position: relative;
            z-index: 2;
        }

        .desc {
            text-align: center;
            font-size: 15px;
            margin: 10px 0;
            position: relative;
            z-index: 2;
        }

        .specs {
            text-align: center;
            font-family: monospace;
            font-size: 14px;
            margin-top: 15px;
            position: relative;
            z-index: 2;
        }

        .footer {
            text-align: center;
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            font-size: 12px;
            opacity: 0.5;
            color: white;
        }

        /* ===== LEKHA - TOKYO GHOUL with MASK ANIMATION ===== */
        .lekha-style {
            background: #0a0000;
            border: 2px solid #cc0000;
            box-shadow: 0 0 40px rgba(204,0,0,0.3);
            color: #ff4444;
        }
        .lekha-style h2 {
            color: #cc0000;
            font-family: monospace;
            letter-spacing: 3px;
        }
        .lekha-style .face-img {
            border-color: #cc0000;
            animation: pulseRed 1.5s ease-in-out infinite;
        }
        @keyframes pulseRed {
            0%, 100% { box-shadow: 0 0 0 0 rgba(204,0,0,0.4); }
            50% { box-shadow: 0 0 0 15px rgba(204,0,0,0); }
        }
        .lekha-style::before {
            content: "KAGUNE";
            position: absolute;
            top: 20px;
            right: -30px;
            font-size: 70px;
            opacity: 0.1;
            transform: rotate(15deg);
            pointer-events: none;
            animation: floatMask 4s ease-in-out infinite;
        }
        @keyframes floatMask {
            0%, 100% { transform: rotate(15deg) translateX(0); opacity: 0.1; }
            50% { transform: rotate(15deg) translateX(-10px); opacity: 0.2; }
        }

        /* ===== DIMA - FRIENDLY TAG with FLOATING TAGS ===== */
        .dima-style {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            border: 2px solid #ffdd44;
        }
        .dima-style h2 {
            color: #ffdd44;
        }
        .dima-style .face-img {
            border-color: #ffdd44;
            animation: bounce 2s ease-in-out infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        .dima-style::before {
            content: "#FRIEND #TEAM #LOVE #PEACE #DIMA #BMW #BEST";
            position: absolute;
            bottom: 10px;
            left: 0;
            width: 100%;
            font-size: 12px;
            color: #ffdd44;
            opacity: 0.4;
            text-align: center;
            white-space: nowrap;
            animation: slideTags 8s linear infinite;
            pointer-events: none;
        }
        @keyframes slideTags {
            0% { transform: translateX(100%); opacity: 0; }
            10% { opacity: 0.4; }
            90% { opacity: 0.4; }
            100% { transform: translateX(-100%); opacity: 0; }
        }

        /* ===== KIRYUHA - CYBERPUNK GLITCH ===== */
        .kiryuha-style {
            background: #0b0b2b;
            border: 2px solid #ff00ff;
            box-shadow: 0 0 20px #ff00ff;
            text-shadow: 0 0 5px #ff00ff;
        }
        .kiryuha-style h2 {
            color: #ff00ff;
            font-family: monospace;
            animation: glitch 1.5s infinite;
        }
        @keyframes glitch {
            0%, 100% { text-shadow: 2px 0 #ff00ff, -2px 0 #00ffff; }
            33% { text-shadow: -2px 0 #ff00ff, 2px 0 #00ffff; }
            66% { text-shadow: 2px 2px #ff00ff, -2px -2px #00ffff; }
        }
        .kiryuha-style .face-img {
            border-color: #ff00ff;
            animation: neonFlicker 1.2s infinite;
        }
        @keyframes neonFlicker {
            0%, 100% { filter: drop-shadow(0 0 5px #ff00ff); }
            50% { filter: drop-shadow(0 0 15px #ff00ff); }
        }
        .kiryuha-style::after {
            content: ">_ SYSTEM ONLINE // NEURAL LINK // //";
            position: absolute;
            bottom: 5px;
            left: 10px;
            font-size: 10px;
            color: #0f0;
            font-family: monospace;
            animation: blink 1s step-end infinite;
            pointer-events: none;
        }
        @keyframes blink {
            50% { opacity: 0; }
        }

        /* ===== ZHENEK - RETRO 90s CRT ===== */
        .zhenek-style {
            background: #332200;
            border: 3px dashed #ffaa33;
            position: relative;
        }
        .zhenek-style::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(0deg, rgba(0,0,0,0.2) 0px, rgba(0,0,0,0.2) 2px, transparent 2px, transparent 6px);
            pointer-events: none;
            animation: scanlines 8s linear infinite;
        }
        @keyframes scanlines {
            0% { transform: translateY(0); }
            100% { transform: translateY(100%); }
        }
        .zhenek-style .face-img {
            border-color: #ffaa33;
            border-style: dashed;
            animation: retroShake 0.3s infinite;
        }
        @keyframes retroShake {
            0%, 100% { transform: translate(0, 0); }
            25% { transform: translate(1px, -1px); }
            75% { transform: translate(-1px, 1px); }
        }

        /* ===== AZIM - RACING SPEEDSTER ===== */
        .azim-style {
            background: linear-gradient(135deg, #1a1a00, #331a00);
            border: 2px solid #ff6600;
            position: relative;
        }
        .azim-style h2 {
            color: #ff6600;
            font-family: 'Courier New', monospace;
            letter-spacing: 3px;
        }
        .azim-style .face-img {
            border-color: #ff6600;
            animation: speedPulse 0.8s ease-in-out infinite;
        }
        @keyframes speedPulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 5px #ff6600; }
            50% { transform: scale(1.02); box-shadow: 0 0 20px #ff6600; }
        }
        .azim-style::before {
            content: ">> SPEED MODE >> RACING >>";
            position: absolute;
            top: 10px;
            left: 0;
            width: 100%;
            font-size: 14px;
            color: #ff6600;
            opacity: 0.3;
            text-align: center;
            animation: racingStripes 1s linear infinite;
            white-space: nowrap;
            pointer-events: none;
        }
        @keyframes racingStripes {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }
        .azim-style .car-img {
            animation: carShake 3s ease-in-out infinite;
        }
        @keyframes carShake {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(3px); }
        }

        /* ===== RUSIK - STREET GANGSTA DOLLARS ===== */
        .rusik-style {
            background: #1a1a1a;
            border: 2px solid #ffd700;
            position: relative;
            overflow: hidden;
        }

        .rusik-style h2 {
            color: #ffd700;
            font-family: impact;
            letter-spacing: 2px;
        }

        .rusik-style .face-img {
            border-color: #ffd700;
            border-width: 4px;
            animation: goldShine 1.8s ease-in-out infinite;
        }

        @keyframes goldShine {
            0%, 100% { box-shadow: 0 0 5px gold; }
            50% { box-shadow: 0 0 25px gold; }
        }

        .rusik-gun-left {
            position: absolute;
            left: -80px;
            top: 50%;
            transform: translateY(-50%);
            transition: left 0.4s ease-out;
            z-index: 10;
            pointer-events: none;
        }

        .rusik-style:hover .rusik-gun-left {
            left: 15px;
        }

        .rusik-gun-left img {
            width: 90px;
            filter: drop-shadow(0 0 8px gold);
        }

        .rusik-gun-right {
            position: absolute;
            right: -80px;
            top: 50%;
            transform: translateY(-50%);
            transition: right 0.4s ease-out;
            z-index: 10;
            pointer-events: none;
        }

        .rusik-style:hover .rusik-gun-right {
            right: 15px;
        }

        .rusik-gun-right img {
            width: 100px;
            filter: drop-shadow(0 0 8px gold);
        }

        @keyframes gunFlash {
            0% { opacity: 0; text-shadow: 0 0 0 gold; }
            50% { opacity: 1; text-shadow: 0 0 20px gold; }
            100% { opacity: 0; text-shadow: 0 0 0 gold; }
        }

        .flash-left, .flash-right {
            position: absolute;
            top: 50%;
            font-size: 30px;
            opacity: 0;
            pointer-events: none;
            animation: gunFlash 0.3s ease-out infinite;
            animation-play-state: paused;
        }

        .rusik-style:hover .flash-left {
            left: 100px;
            animation-play-state: running;
        }

        .rusik-style:hover .flash-right {
            right: 100px;
            animation-play-state: running;
        }

        .flash-left {
            left: 80px;
            transform: translateY(-50%);
        }

        .flash-right {
            right: 80px;
            transform: translateY(-50%);
        }
    </style>
</head>
<body>
<div class="container">
    <h1>OUR CARS</h1>
    <div class="sub">ANIMATED STYLES  UNIQUE VIBES</div>

    <div class="tabs">
        <button class="tab-btn" data-tab="lekha">LEKHA  TOKYO GHOUL</button>
        <button class="tab-btn" data-tab="dima">DIMA  FRIENDLY TAG</button>
        <button class="tab-btn" data-tab="kiryuha">KIRYUHA  CYBERPUNK</button>
        <button class="tab-btn" data-tab="zhenek">ZHENEK  RETRO 90s</button>
        <button class="tab-btn" data-tab="rusik">RUSIK  GANGSTA</button>
        <button class="tab-btn" data-tab="azim">AZIM  RACING</button>
    </div>

    <-- LEKHA -->
    <div id="lekha" class="tab-content lekha-style">
        <h2>LEKHA | TOKYO GHOUL</h2>
        <img class="face-img" id="face-lekha" src="https://i.yapx.ru/dzZDy.jpg">
        <img class="car-img" src="https://cdnseo.dreamfaceapp.com/seo/material/1748504052853/2025-05-29/image.webp" alt="Bugatti" onerror="this.src='https://via.placeholder.com/550x300?text=Bugatti+Chiron'">
        <div class="desc">Bugatti Chiron  1600 HP  KAGUNE MODE</div>
        <div class="specs">0-100: 2.4 sec  The Best  Tokyo Ghoul Edition</div>
    </div>

    <!-- DIMA -->
    <div id="dima" class="tab-content dima-style">
        <h2>DIMA | FRIENDLY TAG</h2>
        <img class="face-img" id="face-dima" src="https://i.yapx.ru/dzZRd.jpg">
        <img class="car-img" src="https://avatars.mds.yandex.net/get-autoru-vos/16872780/cff9bbca17a70ced9eab7dcc58d3295f/584x438" alt="BMW M5" onerror="this.src='https://via.placeholder.com/550x300?text=BMW+M5'">
        <div class="desc">BMW M5 Competition  625 HP</div>
        <div class="specs">#FRIENDLYTAG  Always with you  Best vibes</div>
    </div>

    <!-- KIRYUHA -->
    <div id="kiryuha" class="tab-content kiryuha-style">
        <h2>KIRYUHA | CYBERPUNK 2077</h2>
        <img class="face-img" id="face-kiryuha" src="https://i.yapx.ru/dzZUY.jpg">
        <img class="car-img" src="https://avatars.mds.yandex.net/i?id=aa07eb2fbf2a07d9047678b99ff1730d_l-12911696-images-thumbs&n=13" alt="Audi A6" onerror="this.src='https://via.placeholder.com/550x300?text=Audi+A6'">
        <div class="desc">Audi A6  265 HP  Neural Link Ready</div>
        <div class="specs">Neon lights  AI assistant  Cyberpunk style</div>
    </div>

    <!-- ZHENEK -->
    <div id="zhenek" class="tab-content zhenek-style">
        <h2>ZHENEK | RETRO 90s</h2>
        <img class="face-img" id="face-zhenek" src="https://i.yapx.ru/dzZWi.png">
        <img class="car-img" src="https://avatars.mds.yandex.net/get-shedevrum/12155741/img_52cd10b70dfd11ef8431aa83cb71e2b8/orig" alt="Toyota Vista" onerror="this.src='https://via.placeholder.com/550x300?text=Toyota+Vista'">
        <div class="desc">Toyota Mark II  Old school classic</div>
        <div class="specs">Pure mechanics  Drift machine  90s vibes</div>
    </div>

    <!-- RUSIK -->
    <div id="rusik" class="tab-content rusik-style">
        <div class="rusik-gun-left">
            <img src="https://icons.iconarchive.com/icons/icons8/windows-8/256/Weapons-Desert-Eagle-icon.png" alt="Deagle">
        </div>
        <div class="rusik-gun-right">
            <img src="https://icons.iconarchive.com/icons/icons8/windows-8/256/Weapons-AK-47-icon.png" alt="AK47">
        </div>
        <div class="flash-left"></div>
        <div class="flash-right">💥</div>
        <h2>RUSIK | STREET GANGSTA</h2>
        <img class="face-img" id="face-rusik" src="https://i.yapx.ru/dzZK7.jpg">
        <img class="car-img" src="https://avatars.mds.yandex.net/i?id=bad4c307d780ded21c1476e1d3ee47ee_l-5482298-images-thumbs&n=13" alt="Mercedes E63" onerror="this.src='https://via.placeholder.com/550x300?text=Mercedes+E63'">
        <div class="desc">Mercedes-AMG E63  612 HP  Boss Mode</div>
        <div class="specs">V8 Biturbo  Street king  Gold chain edition</div>
    </div>

    <!-- AZIM -->
    <div id="azim" class="tab-content azim-style">
        <h2>AZIM | RACING SPEEDSTER</h2>
        <img class="face-img" src="https://i.yapx.ru/dzZaa.jpg">
        <img class="car-img" src="https://i.pinimg.com/736x/3b/38/41/3b3841be2c2ca0ca9aa25e835c18667b.jpg" alt="Nissan GT-R" onerror="this.src='https://via.placeholder.com/550x300?text=Nissan+GT-R'">
        <div class="desc">Nissan GT-R  600 HP  RACING MODE</div>
        <div class="specs">0-100: 2.8 sec  AWD  Track beast</div>
    </div>

    <div class="footer">
        ZAVTRA SDACHA DOLBAEB
    </div>
</div>

<script>
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            contents.forEach(c => c.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
        });
    });

    document.querySelector('.tab-btn[data-tab="lekha"]').classList.add('active');
</script>
</body>
</html>
