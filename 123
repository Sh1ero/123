<script>
    // ========== THREE DIFFERENT FACES FOR SF, AXE, FURION ==========
    const sfFace = "https://i.yapx.ru/dzZNR.jpg";
    const axeFace = "https://i.yapx.ru/dzdVC.jpg";
    const furionFace = "https://i.yapx.ru/dzdVR.jpg";

    const sfImg = document.getElementById('sf-img');
    const axeImg = document.getElementById('axe-img');
    const furionImg = document.getElementById('furion-img');

    if (sfImg) {
        sfImg.originalSrc = sfImg.src;
        sfImg.addEventListener('mouseenter', () => { sfImg.src = sfFace; });
        sfImg.addEventListener('mouseleave', () => { sfImg.src = sfImg.originalSrc; });
    }
    if (axeImg) {
        axeImg.originalSrc = axeImg.src;
        axeImg.addEventListener('mouseenter', () => { axeImg.src = axeFace; });
        axeImg.addEventListener('mouseleave', () => { axeImg.src = axeImg.originalSrc; });
    }
    if (furionImg) {
        furionImg.originalSrc = furionImg.src;
        furionImg.addEventListener('mouseenter', () => { furionImg.src = furionFace; });
        furionImg.addEventListener('mouseleave', () => { furionImg.src = furionImg.originalSrc; });
    }

    // ========== TABS SWITCHING ==========
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            contents.forEach(c => c.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
        });
    });
</script>
